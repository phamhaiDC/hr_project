generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Branch {
  id          Int             @id @default(autoincrement())
  name        String?
  latitude    Float?
  longitude   Float?
  radius      Int             @default(50)
  code        String?
  officeId    Int?            @map("office_id")
  status      String?         @default("active")
  office      OfficeLocation? @relation(fields: [officeId], references: [id])
  departments Department[]
  employees   Employee[]

  @@map("branch")
}

model Department {
  id          Int        @id @default(autoincrement())
  name        String
  branchId    Int?       @map("branch_id")
  code        String     @unique
  workingType String     @default("FIXED") @map("working_type")
  description String?
  isActive    Boolean    @default(true) @map("is_active")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  branch      Branch?    @relation(fields: [branchId], references: [id])
  employees   Employee[]
  positions   Position[]
  shifts      Shift[]

  @@map("department")
}

model Position {
  id           Int         @id @default(autoincrement())
  name         String
  code         String      @unique
  departmentId Int?        @map("department_id")
  description  String?
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  employees    Employee[]
  department   Department? @relation(fields: [departmentId], references: [id])

  @@map("position")
}

model Employee {
  id                   Int                    @id @default(autoincrement())
  code                 String?                @unique
  fullName             String?                @map("full_name")
  email                String?                @unique
  phone                String?
  branchId             Int?                   @map("branch_id")
  departmentId         Int?                   @map("department_id")
  positionId           Int?                   @map("position_id")
  managerId            Int?                   @map("manager_id")
  status               String?
  joinDate             DateTime?              @map("join_date") @db.Date
  probationEndDate     DateTime?              @map("probation_end_date") @db.Date
  createdAt            DateTime?              @default(now()) @map("created_at")
  updatedAt            DateTime?              @updatedAt @map("updated_at")
  password             String?
  role                 String?                @default("employee")
  officeId             Int?                   @map("office_id")
  workingMode          String?                @default("FIXED") @map("working_mode")
  shiftId              Int?                   @map("shift_id")
  telegramId           String?                @map("telegram_id")
  attendance           Attendance[]
  attendanceLogs       AttendanceLog[]
  auditLogs            AuditLog[]
  contracts            Contract[]
  decisions            Decision[]
  branch               Branch?                @relation(fields: [branchId], references: [id])
  department           Department?            @relation(fields: [departmentId], references: [id])
  manager              Employee?              @relation("ManagerToEmployees", fields: [managerId], references: [id])
  subordinates         Employee[]             @relation("ManagerToEmployees")
  office               OfficeLocation?        @relation(fields: [officeId], references: [id])
  position             Position?              @relation(fields: [positionId], references: [id])
  currentShift         Shift?                 @relation("EmployeeToShift", fields: [shiftId], references: [id])
  performedHistories   EmployeeHistory[]      @relation("ChangedByToHistory")
  histories            EmployeeHistory[]      @relation("EmployeeToHistory")
  leaveAccrualLogs     LeaveAccrualLog[]
  leaveApprovals       LeaveApproval[]        @relation("ApproverToLeaveApprovals")
  leaveBalance         LeaveBalance?
  leaveRequests        LeaveRequest[]
  checklists           OffboardingChecklist[]
  resignationApprovals ResignationApproval[]  @relation("ApproverToResignationApprovals")
  resignationRequests  ResignationRequest[]

  @@map("employee")
}

model SystemConfig {
  key         String  @id
  value       String
  description String?

  @@map("system_config")
}

model Contract {
  id         Int       @id @default(autoincrement())
  employeeId Int?      @map("employee_id")
  type       String?
  startDate  DateTime? @map("start_date") @db.Date
  endDate    DateTime? @map("end_date") @db.Date
  status     String?
  createdAt  DateTime? @default(now()) @map("created_at")
  employee   Employee? @relation(fields: [employeeId], references: [id])

  @@map("contract")
}

model LeaveRequest {
  id          Int             @id @default(autoincrement())
  employeeId  Int?            @map("employee_id")
  fromDate    DateTime?       @map("from_date") @db.Date
  toDate      DateTime?       @map("to_date") @db.Date
  type        String?
  status      String?         @default("pending")
  currentStep Int?            @default(1) @map("current_step")
  createdAt   DateTime?       @default(now()) @map("created_at")
  reason      String?
  days        Int?
  approvals   LeaveApproval[]
  employee    Employee?       @relation(fields: [employeeId], references: [id])

  @@map("leave_request")
}

model LeaveApproval {
  id           Int           @id @default(autoincrement())
  requestId    Int?          @map("request_id")
  step         Int?
  approverId   Int?          @map("approver_id")
  status       String?       @default("pending")
  actionTime   DateTime?     @map("action_time")
  approverRole String?       @map("approver_role")
  comments     String?
  approver     Employee?     @relation("ApproverToLeaveApprovals", fields: [approverId], references: [id])
  request      LeaveRequest? @relation(fields: [requestId], references: [id])

  @@unique([requestId, step])
  @@map("leave_approval")
}

model LeaveBalance {
  employeeId Int      @id @map("employee_id")
  total      Decimal  @default(0) @db.Decimal(10, 1)
  used       Decimal  @default(0) @db.Decimal(10, 1)
  remaining  Decimal  @default(0) @db.Decimal(10, 1)
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")
  employee   Employee @relation(fields: [employeeId], references: [id])

  @@map("leave_balance")
}

model LeaveAccrualLog {
  id          Int      @id @default(autoincrement())
  employeeId  Int      @map("employee_id")
  days        Decimal  @db.Decimal(10, 1)
  note        String?
  accrualDate DateTime @map("accrual_date") @db.Date
  createdAt   DateTime @default(now()) @map("created_at")
  employee    Employee @relation(fields: [employeeId], references: [id])

  @@map("leave_accrual_log")
}

model CalendarYear {
  id          Int      @id @default(autoincrement())
  year        Int      @unique
  weekendDays Int[]    @map("weekend_days")
  country     String?
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("calendar_year")
}

model CalendarDay {
  id     Int      @id @default(autoincrement())
  year   Int
  date   DateTime @unique @db.Date
  type   String
  isPaid Boolean  @default(true) @map("is_paid")
  note   String?

  @@map("calendar_day")
}

model Holiday {
  id          Int      @id @default(autoincrement())
  name        String
  fromDate    DateTime @map("from_date") @db.Date
  toDate      DateTime @map("to_date") @db.Date
  isPaid      Boolean  @default(true) @map("is_paid")
  isRecurring Boolean  @default(false) @map("is_recurring")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("holiday")
}

model OfficeLocation {
  id        Int        @id @default(autoincrement())
  name      String
  latitude  Float
  longitude Float
  radius    Int
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  branches  Branch[]
  employees Employee[]

  @@map("office_location")
}

model Shift {
  id                Int                       @id @default(autoincrement())
  name              String
  startTime         String                    @map("start_time")
  endTime           String                    @map("end_time")
  breakMinutes      Int                       @default(60) @map("break_minutes")
  graceLateMinutes  Int                       @default(15) @map("grace_late_minutes")
  graceEarlyMinutes Int                       @default(15) @map("grace_early_minutes")
  isDefault         Boolean                   @default(false) @map("is_default")
  createdAt         DateTime                  @default(now()) @map("created_at")
  isCrossDay        Boolean                   @default(false) @map("is_cross_day")
  departmentId      Int?                      @map("department_id")
  code              String                    @unique
  isActive          Boolean                   @default(true) @map("is_active")
  attendances       Attendance[]
  currentEmployees  Employee[]                @relation("EmployeeToShift")
  assignments       EmployeeShiftAssignment[]
  department        Department?               @relation(fields: [departmentId], references: [id])

  @@map("shift")
}

model EmployeeShiftAssignment {
  id            Int      @id @default(autoincrement())
  employeeId    Int      @map("employee_id")
  shiftId       Int      @map("shift_id")
  effectiveDate DateTime @map("effective_date") @db.Date
  createdAt     DateTime @default(now()) @map("created_at")
  shift         Shift    @relation(fields: [shiftId], references: [id])

  @@map("employee_shift_assignment")
}

model WorkLocation {
  id        Int      @id @default(autoincrement())
  name      String
  lat       Float
  lng       Float
  radius    Int
  address   String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("work_location")
}

model AttendanceLog {
  id           Int      @id @default(autoincrement())
  employeeId   Int      @map("employee_id")
  time         DateTime
  type         String
  lat          Float?
  lng          Float?
  locationId   Int?     @map("location_id")
  deviceId     String?  @map("device_id")
  distanceM    Float?   @map("distance_m")
  attendanceId Int?     @map("attendance_id")
  createdAt    DateTime @default(now()) @map("created_at")
  note         String?  @map("note")
  employee     Employee @relation(fields: [employeeId], references: [id])

  @@map("attendance_log")
}

model Attendance {
  id              Int       @id @default(autoincrement())
  employeeId      Int?      @map("employee_id")
  date            DateTime? @db.Date
  checkinTime     DateTime? @map("checkin_time")
  checkoutTime    DateTime? @map("checkout_time")
  workingHours    Decimal?  @map("working_hours") @db.Decimal(5, 2)
  checkinLat      Float?    @map("checkin_lat")
  checkinLng      Float?    @map("checkin_lng")
  checkoutLat     Float?    @map("checkout_lat")
  checkoutLng     Float?    @map("checkout_lng")
  isEarlyOut      Boolean   @default(false) @map("is_early_out")
  isLate          Boolean   @default(false) @map("is_late")
  isOvertime      Boolean   @default(false) @map("is_overtime")
  overtimeHours   Decimal?  @map("overtime_hours") @db.Decimal(5, 2)
  shiftId         Int?      @map("shift_id")
  isOnLeave       Boolean   @default(false) @map("is_on_leave")
  leaveRequestId  Int?      @map("leave_request_id")
  officeDistanceM Float?    @map("office_distance_m")
  isInOffice      Boolean   @default(false) @map("is_in_office")
  locationNote    String?   @map("location_note")
  hasLocation     Boolean   @default(false) @map("has_location")
  checkinNote     String?   @map("checkin_note")
  checkoutNote    String?   @map("checkout_note")
  employee        Employee? @relation(fields: [employeeId], references: [id])
  shift           Shift?    @relation(fields: [shiftId], references: [id])

  @@unique([employeeId, date])
  @@map("attendance")
}

model AttendanceRaw {
  id           Int       @id @default(autoincrement())
  employeeCode String?   @map("employee_code")
  timestamp    DateTime?

  @@map("attendance_raw")
}

model ApprovalFlow {
  id    Int            @id @default(autoincrement())
  type  String?
  steps ApprovalStep[]

  @@map("approval_flow")
}

model ApprovalStep {
  id           Int           @id @default(autoincrement())
  flowId       Int?          @map("flow_id")
  stepOrder    Int?          @map("step_order")
  approverType String?       @map("approver_type")
  flow         ApprovalFlow? @relation(fields: [flowId], references: [id])

  @@map("approval_step")
}

model ResignationRequest {
  id              Int                   @id @default(autoincrement())
  employeeId      Int?                  @map("employee_id")
  lastWorkingDate DateTime?             @map("last_working_date") @db.Date
  reason          String?
  status          String?               @default("pending")
  currentStep     Int?                  @default(1) @map("current_step")
  createdAt       DateTime?             @default(now()) @map("created_at")
  updatedAt       DateTime?             @updatedAt @map("updated_at")
  approvals       ResignationApproval[]
  employee        Employee?             @relation(fields: [employeeId], references: [id])

  @@map("resignation_request")
}

model ResignationApproval {
  id           Int                 @id @default(autoincrement())
  requestId    Int?                @map("request_id")
  step         Int?
  approverId   Int?                @map("approver_id")
  approverRole String?             @map("approver_role")
  status       String?             @default("pending")
  comments     String?
  actionTime   DateTime?           @map("action_time")
  approver     Employee?           @relation("ApproverToResignationApprovals", fields: [approverId], references: [id])
  request      ResignationRequest? @relation(fields: [requestId], references: [id])

  @@unique([requestId, step])
  @@map("resignation_approval")
}

model OffboardingChecklist {
  id         Int       @id @default(autoincrement())
  employeeId Int?      @map("employee_id")
  item       String?
  status     String?   @default("pending")
  createdAt  DateTime? @default(now()) @map("created_at")
  employee   Employee? @relation(fields: [employeeId], references: [id])

  @@map("offboarding_checklist")
}

model Decision {
  id         Int       @id @default(autoincrement())
  employeeId Int?      @map("employee_id")
  type       String?
  reason     String?
  amount     Decimal?
  date       DateTime? @db.Date
  employee   Employee? @relation(fields: [employeeId], references: [id])

  @@map("decision")
}

model EmployeeHistory {
  id            Int       @id @default(autoincrement())
  employeeId    Int?      @map("employee_id")
  field         String?
  oldValue      String?   @map("old_value")
  newValue      String?   @map("new_value")
  effectiveDate DateTime? @default(now()) @map("effective_date") @db.Date
  changedBy     Int?      @map("changed_by")
  createdAt     DateTime  @default(now()) @map("created_at")
  performer     Employee? @relation("ChangedByToHistory", fields: [changedBy], references: [id])
  employee      Employee? @relation("EmployeeToHistory", fields: [employeeId], references: [id])

  @@map("employee_history")
}

model AuditLog {
  id        Int       @id @default(autoincrement())
  userId    Int?      @map("user_id")
  action    String?
  entity    String?
  entityId  Int?      @map("entity_id")
  timestamp DateTime  @default(now())
  details   Json?     @map("details")
  user      Employee? @relation(fields: [userId], references: [id])

  @@map("audit_log")
}
