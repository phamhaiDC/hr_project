{
  "name": "hr-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0 --webpack",
    "dev:webpack": "next dev --hostname 0.0.0.0 --webpack",
    "dev:https": "next dev --hostname dcorp.vn --port 3000 --webpack --experimental-https --experimental-https-key certificates/dcorp.vn-key.pem --experimental-https-cert certificates/dcorp.vn.pem",
    "dev:dual": "node server-dual.mjs",
    "dev:proxy": "node https-proxy.mjs",
    "certs": "bash scripts/gen-cert.sh",
    "clean": "rm -rf .next",
    "build": "next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
